def gerar_codigo(i, enunciado):
    c = ""
    c += f"// Exercício {i:02d}\n"
    c += f"// {enunciado}\n\n"
    c += "import java.util.Scanner;\n\n"
    c += f"public class lista{i:02d} " + "{\n"
    c += "    public static void main(String[] args) {\n"
    c += "        Scanner sc = new Scanner(System.in);\n\n"

    # ===== TODOS OS EXERCÍCIOS =====

    if i == 1:
        c += 'int n=sc.nextInt(); System.out.println(n);\n'
    elif i == 2:
        c += 'double n=sc.nextDouble(); System.out.println(n);\n'
    elif i == 3:
        c += 'int a=sc.nextInt(),b=sc.nextInt(),d=sc.nextInt(); System.out.println(a+b+d);\n'
    elif i == 4:
        c += 'double n=sc.nextDouble(); System.out.println(n*n);\n'
    elif i == 5:
        c += 'double n=sc.nextDouble(); System.out.println(n/5);\n'
    elif i == 6:
        c += 'double c1=sc.nextDouble(); System.out.println(c1*(9.0/5.0)+32);\n'
    elif i == 7:
        c += 'double f=sc.nextDouble(); System.out.println(5.0*(f-32)/9.0);\n'
    elif i == 8:
        c += 'double k=sc.nextDouble(); System.out.println(k-273.15);\n'
    elif i == 9:
        c += 'double c1=sc.nextDouble(); System.out.println(c1+273.15);\n'
    elif i == 10:
        c += 'double k=sc.nextDouble(); System.out.println(k/3.6);\n'
    elif i == 11:
        c += 'double m=sc.nextDouble(); System.out.println(m*3.6);\n'
    elif i == 12:
        c += 'double m=sc.nextDouble(); System.out.println(1.61*m);\n'
    elif i == 13:
        c += 'double k=sc.nextDouble(); System.out.println(k/1.61);\n'
    elif i == 14:
        c += 'double g=sc.nextDouble(); System.out.println(g*3.14/180);\n'
    elif i == 15:
        c += 'double r=sc.nextDouble(); System.out.println(r*180/3.14);\n'
    elif i == 16:
        c += 'double p=sc.nextDouble(); System.out.println(p*2.54);\n'
    elif i == 17:
        c += 'double cm=sc.nextDouble(); System.out.println(cm/2.54);\n'
    elif i == 18:
        c += 'double m=sc.nextDouble(); System.out.println(m*1000);\n'
    elif i == 19:
        c += 'double l=sc.nextDouble(); System.out.println(l/1000);\n'
    elif i == 20:
        c += 'double k=sc.nextDouble(); System.out.println(k/0.45);\n'
    elif i == 21:
        c += 'double l=sc.nextDouble(); System.out.println(l*0.45);\n'
    elif i == 22:
        c += 'double j=sc.nextDouble(); System.out.println(0.91*j);\n'
    elif i == 23:
        c += 'double m=sc.nextDouble(); System.out.println(m/0.91);\n'
    elif i == 24:
        c += 'double m=sc.nextDouble(); System.out.println(m*0.000247);\n'
    elif i == 25:
        c += 'double a=sc.nextDouble(); System.out.println(a*4048.58);\n'
    elif i == 26:
        c += 'double m=sc.nextDouble(); System.out.println(m*0.0001);\n'
    elif i == 27:
        c += 'double h=sc.nextDouble(); System.out.println(h*10000);\n'
    elif i == 28:
        c += 'double a=sc.nextDouble(),b=sc.nextDouble(),d=sc.nextDouble(); System.out.println(a*a+b*b+d*d);\n'
    elif i == 29:
        c += 'double n1=sc.nextDouble(),n2=sc.nextDouble(),n3=sc.nextDouble(),n4=sc.nextDouble(); System.out.println((n1+n2+n3+n4)/4);\n'
    elif i == 30:
        c += 'double r=sc.nextDouble(),c1=sc.nextDouble(); System.out.println(r/c1);\n'
    elif i == 31:
        c += 'int n=sc.nextInt(); System.out.println(n-1); System.out.println(n+1);\n'
    elif i == 32:
        c += 'int n=sc.nextInt(); System.out.println((n*3+1)+(n*2-1));\n'
    elif i == 33:
        c += 'double l=sc.nextDouble(); System.out.println(l*l);\n'
    elif i == 34:
        c += 'double r=sc.nextDouble(); System.out.println(3.141592*r*r);\n'
    elif i == 35:
        c += 'double a=sc.nextDouble(),b=sc.nextDouble(); System.out.println(Math.sqrt(a*a+b*b));\n'
    elif i == 36:
        c += 'double r=sc.nextDouble(),h=sc.nextDouble(); System.out.println(3.141592*r*r*h);\n'
    elif i == 37:
        c += 'double v=sc.nextDouble(); System.out.println(v*0.88);\n'
    elif i == 38:
        c += 'double s=sc.nextDouble(); System.out.println(s*1.25);\n'
    elif i == 39:
        c += 'double t=780000; System.out.println(t*0.46); System.out.println(t*0.32); System.out.println(t*0.22);\n'
    elif i == 40:
        c += 'int d=sc.nextInt(); double s=d*30; System.out.println(s*0.92);\n'
    elif i == 41:
        c += 'double vh=sc.nextDouble(),h=sc.nextDouble(); System.out.println(vh*h*1.10);\n'
    elif i == 42:
        c += 'double s=sc.nextDouble(); System.out.println(s*1.05*0.93);\n'
    elif i == 43:
        c += 'double v=sc.nextDouble(); double vista=v*0.9; System.out.println(vista); System.out.println(v/3); System.out.println(vista*0.05); System.out.println(v*0.05);\n'
    elif i == 44:
        c += 'double alt=sc.nextDouble(),d=sc.nextDouble(); System.out.println((int)(alt/d));\n'
    elif i == 45:
        c += 'char ch=sc.next().charAt(0); System.out.println((char)(ch+32));\n'
    elif i == 46:
        c += 'int n=sc.nextInt(); int a=n/100,b=(n/10)%10,d=n%10; System.out.println(d*100+b*10+a);\n'
    elif i == 47:
        c += 'int n=sc.nextInt(); System.out.println(n/1000); System.out.println((n/100)%10); System.out.println((n/10)%10); System.out.println(n%10);\n'
    elif i == 48:
        c += 'int s=sc.nextInt(); int h=s/3600,m=(s%3600)/60,seg=s%60; System.out.println(h+":"+m+":"+seg);\n'
    elif i == 49:
        c += 'int h=sc.nextInt(),m=sc.nextInt(),s=sc.nextInt(),d=sc.nextInt(); int total=h*3600+m*60+s+d; System.out.println((total/3600)%24+":"+(total%3600)/60+":"+total%60);\n'
    elif i == 50:
        c += 'double a=sc.nextDouble(),b=sc.nextDouble(),d=sc.nextDouble(),p=sc.nextDouble(); double soma=a+b+d; System.out.println(a/soma*p); System.out.println(b/soma*p); System.out.println(d/soma*p);\n'

    c += "\n        sc.close();\n"
    c += "    }\n"
    c += "}\n"
    return c


for i in range(1, 51):
    with open(f"lista{i:02d}.java", "w", encoding="utf-8") as f:
        f.write(gerar_codigo(i, exercicios[i-1]))

print("✅ 50 arquivos Java com enunciado e resolução criados!")