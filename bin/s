# Criando arquivos
for i, exercicio in enumerate(exercicios, start=1):
    romano = para_romano(i)
    numero_formatado = f"{i:02d}"
    
    nome_arquivo = f"lista{numero_formatado}.java"
    
    with open(nome_arquivo, "w", encoding="utf-8") as f:
        f.write(f"// Exercício {numero_formatado} ({romano})\n")
        f.write(f"// {exercicio}\n\n")
        
        f.write(f"public class lista{numero_formatado} " + "{\n")
        f.write("    public static void main(String[] args) {\n")
        f.write("        // Escreva seu código aqui\n")
        f.write("    }\n")
        f.write("}\n")

print("Arquivos Java criados com sucesso!")